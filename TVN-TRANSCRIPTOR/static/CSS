/* Animación de ondas de audio para cuando se está procesando la transcripción */
.audio-wave-animation {
    display: flex;
    align-items: center;
    gap: 3px;
}
.audio-wave-bar {
    width: 4px;
    height: 15px;
    background-color: #ef4444; /* Rojo 24 Horas */
    animation: bounce 1s ease-in-out infinite;
}
.audio-wave-bar:nth-child(2) { animation-delay: 0.2s; }
.audio-wave-bar:nth-child(3) { animation-delay: 0.4s; }

@keyframes bounce {
    0%, 100% { height: 5px; }
    50% { height: 25px; }
}

/* Efecto de brillo de procesamiento para prensa */
.glow-pulse {
    box-shadow: 0 0 15px rgba(239, 68, 68, 0.4);
    animation: pulseGlow 2s infinite;
}

@keyframes pulseGlow {
    0%, 100% { opacity: 0.6; }
    50% { opacity: 1; }
}
